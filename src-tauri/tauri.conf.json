{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vidralo",
  "version": "0.1.0",
  "identifier": "com.vidralo.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vidralo — Local-First Video Downloader",
        "width": 1000,
        "height": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "AIEraDev",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/yt-dlp", "binaries/bgutil-pot"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIyN0NCRDQ3RjUxMzAxNgpSV1FXTUZGLzFNc25DeFNjSHBQMGZCUTlkZXpSVkVnVUJ0RjFpT21LZTZyVjJXMXU4eXIxL1lERko=",
      "endpoints": ["https://github.com/AIEraDev/vidralo/releases/latest/download/latest.json"],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
